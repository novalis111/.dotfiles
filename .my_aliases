# ~/.dotfiles/.my_aliases — modern, GNU/Linux, bevorzugt aktuelles Tooling mit Fallback.

## ls — eza falls da, sonst GNU ls
if command -v eza >/dev/null 2>&1; then
    alias l="eza --group-directories-first"
    alias ll="eza -lah --group-directories-first --git"
    alias lt="eza --tree --level=2"
else
    alias l="ls --color=auto -h"
    alias ll="ls --color=auto -lAh"
fi
alias c="clear"

## cat / grep / find — moderne Tools falls installiert
command -v bat      >/dev/null 2>&1 && alias cat="bat --paging=never"
command -v rg       >/dev/null 2>&1 && alias grep="rg"
command -v fd       >/dev/null 2>&1 && alias find="fd"

## git
alias gst="git status"
alias glog="git log --pretty=tformat:'%h %Cblue%cr%Creset %cn %Cgreen%s%Creset'"
alias gd="git diff"

## navigation
alias ..="cd .."
alias ...="cd ../.."
alias .3="cd ../../.."
alias .4="cd ../../../.."

## battlecat (Dev-Host) — mosh gegen WLAN-Latenz, predictive echo
alias bc="mosh ingo@battlecat"                 # schnell rauf auf den Dev-Host
alias bcssh="ssh battlecat"                     # Fallback ohne mosh (UDP blockiert)

## system
alias ports="ss -tulpn"                       # offene Ports (netstat ist deprecated)
alias lsmount="findmnt"                        # lesbare Mounts (mount-Alias bricht echtes Mounten!)
alias hgr="history | grep -i"
alias updeb="sudo apt-get update && sudo apt-get upgrade -y && sudo apt-get autoremove -y && sudo apt-get autoclean"

## dotfiles aktualisieren (git pull -> Symlinks sind sofort live; install.sh nur fuer neue Dateien)
alias updot="git -C ~/.dotfiles pull && bash ~/.dotfiles/install.sh"

## essentials installieren (modernes Tooling)
alias instess="sudo apt install -y tmux git neovim rsync htop bash-completion ripgrep fd-find bat eza zoxide fzf direnv"
