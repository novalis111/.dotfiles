# ~/.dotfiles/.my_bash — bash-Funktionen, Prompt, PATH, Tool-Hooks
# Wird von ~/.bashrc gesourct (eine geguardete Zeile, via install.sh).

##### tm: DIE kanonische Orko-Session — Highlander, Name IMMER 'orko' #####
# Ein Wort -> rein in die Werkbank. Session existiert -> attach. Sonst -> neu,
# leer, in ~/orko. NIEMALS eine zweite Session spawnen (User-Direktive 2026-06-13).
# Claude startest du SELBST im Window (einfach 'claude' tippen).
# Detach: Ctrl+a d  |  zurueck: tm  |  Liste: tmls
# Die Logik als EIN inline-Befehl, damit sie remote (ueber ssh) identisch laeuft —
# unabhaengig davon, ob das Remote-.bashrc in nicht-interaktiven Shells abbricht
# (klassische "If not running interactively, don't do anything"-Falle).
# Hub-Window-Auto-Move: der Hub (claude·orko) soll IMMER auf Window-Index 0 liegen
# (Owner-Wunsch 2026-06-17). base-index 0 deckt NUR neu erstellte Sessions ab — eine
# laengst laufende orko-Session muss aktiv umgezogen werden. Idempotent + defensiv:
# nur schieben, wenn Index 0 frei ist UND das Hub-Window woanders liegt (nie einen
# laufenden Loop ueberschreiben). renumber-windows=off (feste Loop-Indizes) wird NICHT
# angetastet — move-window ist atomar und laesst alle anderen Fenster in Ruhe.
__orko_hub_to_front='sess=orko; \
tmux has-session -t "$sess" 2>/dev/null || exit 0; \
tmux list-windows -t "$sess" -F "#{window_index}" | grep -qx 0 && exit 0; \
hubidx=$(tmux list-windows -t "$sess" -F "#{window_index} #{window_name}" | awk "/claude.orko/{print \$1; exit}"); \
[ -n "$hubidx" ] && tmux move-window -s "$sess:$hubidx" -t "$sess:0" 2>/dev/null; \
exit 0'
__orko_attach='sess=orko; root="$HOME/orko"; \
command -v tmux >/dev/null 2>&1 || { echo "tmux fehlt"; exit 1; }; \
if tmux has-session -t "$sess" 2>/dev/null; then \
  ( eval "$__orko_hub_to_front" ); \
  exec tmux attach -t "$sess"; \
else exec tmux new-session -s "$sess" -c "$root"; fi'

tm() {
    eval "$__orko_attach"
}
alias tmls="tmux ls"

# omi: "Orko Mini" im AKTUELLEN Verzeichnis — kleiner Worker-Orko fuer Projekt-
# arbeit, KEIN Orchestrierer. Startet Claude direkt hier (kein neues Window) mit
# einem Initialprompt, der das Loop-Spawnen verbietet. (User-Direktive 2026-06-15)
#   omi              -> Orko Mini im $PWD
#   omi "tu X"       -> mit erstem Auftrag
omi() {
    command -v claude >/dev/null 2>&1 || { echo "claude-CLI fehlt"; return 1; }
    # System-Prompt-Append = Regel haelt die GANZE Session (nicht nur 1. Nachricht).
    local sys="Du bist 'Orko Mini' — ein kleiner Worker-Orko fuer Projektarbeit im aktuellen Verzeichnis. NIX SPAWNEN: wenn du Orko bist, KEINE tmux-Loops (orko_spawn_*/orko_loops/orko_loop_doctor), keine Deploys, kein Orchestrieren/Babysitten anderer Sessions — nur die Arbeit hier."
    if [[ -n "$1" ]]; then
        claude --model opus --append-system-prompt "$sys" "$*"
    else
        claude --model opus --append-system-prompt "$sys"
    fi
}

# tmux-Server killen — mit Nachfrage (24/7-Sessions sind eine Fusswaffe)
tmk() {
    read -rp "Wirklich ALLE tmux-Sessions killen? (y/N) " a
    [[ "$a" =~ ^[Yy]$ ]] && tmux kill-server
}

##### git: schneller add+commit+push (nimmt ALLES untracked mit — bewusst grob) #####
gdrop() {
    git add -A && git commit -m "${1:-auto commit}" && git push
}

##### battlecat: ein Wort -> rein in die Werkbank #####
# Lokal AUF battlecat:  identisch zu 'tm' (attach an 'orko', sonst neu).
# Von WSL2/woanders:    mosh (ueberlebt WLAN-Wechsel/Schlaf) -> LAN wenn erreichbar,
#                       sonst MyFRITZ. Landet direkt in tmux 'orko'.
# Secrets (MyFRITZ-Adresse, LAN-IP, Port) kommen aus ~/.config/battlecat.env
#   (LOKAL, NICHT im oeffentlichen dotfiles-Repo). Ohne env -> klarer Hinweis.
battlecat() {
    # Lokal auf battlecat selbst: direkt in tmux, kein Netz.
    if [[ "$(hostname)" == "battlecat" ]]; then
        eval "$__orko_attach"; return
    fi
    # Remote: Secrets laden
    local envf="$HOME/.config/battlecat.env"
    [[ -r "$envf" ]] || { echo "🐱 ~/.config/battlecat.env fehlt — leg sie an (BATTLECAT_EXT/LAN/PORT/USER)"; return 1; }
    # shellcheck disable=SC1090
    . "$envf"
    command -v mosh >/dev/null 2>&1 || { echo "mosh fehlt: sudo apt install mosh"; return 1; }
    # LAN-SSH laeuft auf Port 22 (Default), nur die MyFRITZ-Freigabe nach aussen ist $BATTLECAT_PORT (993).
    # Daher: LAN-Zweig testet+nutzt BATTLECAT_LAN_PORT (Default 22), Extern-Zweig BATTLECAT_PORT.
    local lanport="${BATTLECAT_LAN_PORT:-22}"
    local host port
    if command -v nc >/dev/null 2>&1 && nc -z -w1 "$BATTLECAT_LAN" "$lanport" 2>/dev/null; then
        host="$BATTLECAT_LAN"; port="$lanport"; echo "🐱 battlecat via LAN ($host:$port)"
    else
        host="$BATTLECAT_EXT"; port="$BATTLECAT_PORT"; echo "🐱 battlecat via MyFRITZ ($host:$port)"
    fi
    # mosh: SSH nur fuer Handshake (Port + Key), dann UDP. Direkt in tmux 'orko'.
    exec mosh --ssh="ssh -p $port -i $HOME/.ssh/iterp" "$BATTLECAT_USER@$host" -- bash -lc "$__orko_attach"
}

# bctunnel — battlecat-Web-Ports auf den lokalen WSL2-Client forwarden.
# Danach im Windows-Browser: http://localhost:<port>. Strg+C beendet den Tunnel.
# Gleiche Adress-Aufloesung wie battlecat() (LAN-Test → MyFRITZ-Fallback).
# Ports (Default-Set, ueberschreibbar via BCTUNNEL_PORTS="3100 8100 ..."):
#   3100 lc-Frontend · 8100 lc-API · 5173 Vite · 8233 Temporal-UI · 9101 MinIO-Console
#   8026 Mailpit · 9222 Chrome-DevTools (zum Mitschauen, was Orko sieht)
bctunnel() {
    local envf="$HOME/.config/battlecat.env"
    [[ -r "$envf" ]] || { echo "🐱 ~/.config/battlecat.env fehlt (BATTLECAT_EXT/LAN/PORT/USER)"; return 1; }
    # shellcheck disable=SC1090
    . "$envf"
    # LAN-SSH = Port 22 (Default), MyFRITZ-Freigabe nach aussen = $BATTLECAT_PORT (993).
    local lanport="${BATTLECAT_LAN_PORT:-22}"
    local host port
    if command -v nc >/dev/null 2>&1 && nc -z -w1 "$BATTLECAT_LAN" "$lanport" 2>/dev/null; then
        host="$BATTLECAT_LAN"; port="$lanport"; echo "🐱 bctunnel via LAN ($host:$port)"
    else
        host="$BATTLECAT_EXT"; port="$BATTLECAT_PORT"; echo "🐱 bctunnel via MyFRITZ ($host:$port)"
    fi
    local ports="${BCTUNNEL_PORTS:-3100 8100 5173 8233 9101 8026 9222}"
    # Bind-Adresse: Default 127.0.0.1. In WSL2 mit NAT/ohne localhostForwarding kommt der
    # Windows-Browser an 127.0.0.1 (WSL-intern) NICHT ran -> dann BCTUNNEL_BIND=0.0.0.0 setzen
    # und im Windows-Browser die WSL-IP statt localhost ansteuern (wird unten angezeigt).
    local bind="${BCTUNNEL_BIND:-127.0.0.1}"
    local fwd=() p
    for p in $ports; do fwd+=(-L "$bind:$p:127.0.0.1:$p"); done
    echo "🐱 Forward ($bind): $ports"
    if [[ "$bind" == "0.0.0.0" ]]; then
        local wslip; wslip=$(ip -4 addr show eth0 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1)
        echo "   → Windows-Browser: $(for p in $ports; do printf 'http://%s:%s  ' "${wslip:-<WSL-IP>}" "$p"; done)"
    else
        echo "   → Browser: $(for p in $ports; do printf 'http://localhost:%s  ' "$p"; done)"
    fi
    echo "   (Strg+C beendet den Tunnel)"
    exec ssh -N -p "$port" -i "$HOME/.ssh/iterp" "${fwd[@]}" "$BATTLECAT_USER@$host"
}

# bcweb — bctunnel im Hintergrund + Leitivo-URL fuer den Windows-Browser ausgeben.
# Bindet per Default auf 0.0.0.0, weil Windows-Browser den WSL-internen 127.0.0.1 bei NAT/ohne
# localhostForwarding NICHT erreicht (ERR_CONNECTION_RESET). Ueber die WSL-IP klappt es immer.
# Tunnel laeuft als Hintergrund-Job; Ende mit:  bcweb stop.
# Override:  BCWEB_PATH=/dashboard  BCTUNNEL_PORTS="3100 8100"  BCTUNNEL_BIND=127.0.0.1  bcweb
bcweb() {
    if [[ "$1" == "stop" ]]; then
        pkill -f 'ssh -N .*:3100:127.0.0.1:3100' && echo "🐱 bcweb-Tunnel beendet." || echo "🐱 kein bcweb-Tunnel aktiv."
        return
    fi
    local envf="$HOME/.config/battlecat.env"
    [[ -r "$envf" ]] || { echo "🐱 ~/.config/battlecat.env fehlt"; return 1; }
    # shellcheck disable=SC1090
    . "$envf"
    local path="${BCWEB_PATH:-/login}"
    local bind="${BCTUNNEL_BIND:-0.0.0.0}"
    local ports="${BCTUNNEL_PORTS:-3100 8100}"
    local wslip; wslip=$(ip -4 addr show eth0 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1)
    local hosturl; [[ "$bind" == "0.0.0.0" ]] && hosturl="$wslip" || hosturl="localhost"
    # Host/Port: LAN (Port 22) testen, sonst MyFRITZ.
    local lanport="${BATTLECAT_LAN_PORT:-22}" host port
    if command -v nc >/dev/null 2>&1 && nc -z -w1 "$BATTLECAT_LAN" "$lanport" 2>/dev/null; then
        host="$BATTLECAT_LAN"; port="$lanport"; echo "🐱 bcweb via LAN ($host:$port), bind $bind"
    else
        host="$BATTLECAT_EXT"; port="$BATTLECAT_PORT"; echo "🐱 bcweb via MyFRITZ ($host:$port), bind $bind"
    fi
    pkill -f 'ssh -N .*:3100:127.0.0.1:3100' 2>/dev/null  # alten Tunnel ersetzen
    local fwd=() p; for p in $ports; do fwd+=(-L "$bind:$p:127.0.0.1:$p"); done
    local log="/tmp/bcweb.log"
    # Eigenes ssh (NICHT via bctunnel-exec-im-Subshell -> Fehler sichtbar). ExitOnForwardFailure:
    # scheitert der Bind, stirbt ssh sofort statt halb zu laufen.
    nohup ssh -N -o ExitOnForwardFailure=yes -o ConnectTimeout=8 -o BatchMode=yes \
        -p "$port" -i "$HOME/.ssh/iterp" "${fwd[@]}" "$BATTLECAT_USER@$host" >"$log" 2>&1 &
    local sshpid=$!
    echo "🐱 Warte auf Tunnel-Port 3100 (max 15s)…"
    local i ok=0
    for i in $(seq 1 15); do
        kill -0 "$sshpid" 2>/dev/null || break   # ssh gestorben -> raus
        curl -s -o /dev/null --max-time 1 "http://127.0.0.1:3100/" && { ok=1; break; }
        sleep 1
    done
    if [[ "$ok" != 1 ]]; then
        echo "🐱 ❌ Tunnel kam nicht hoch. ssh-Ausgabe:"; sed 's/^/      /' "$log" 2>/dev/null
        kill "$sshpid" 2>/dev/null; return 1
    fi
    echo "🐱 ✓ Tunnel steht (bind $bind:3100). Im WINDOWS-Browser oeffnen:"
    echo "      http://${hosturl}:3100${path}"
    echo "🐱 Beenden:  bcweb stop"
}

##### aliases laden #####
[ -r "${HOME}/.dotfiles/.my_aliases" ] && . "${HOME}/.dotfiles/.my_aliases"

##### PATH #####
[ -d "${HOME}/bin" ]        && export PATH="${HOME}/bin:$PATH"
[ -d "${HOME}/.local/bin" ] && export PATH="${HOME}/.local/bin:$PATH"
[ -d "${HOME}/.cargo/bin" ] && export PATH="${HOME}/.cargo/bin:$PATH"

##### Tool-Hooks (alle geguarded — kosten nichts, wenn nicht installiert) #####
[ -r "${HOME}/miniconda3/etc/profile.d/conda.sh" ] && . "${HOME}/miniconda3/etc/profile.d/conda.sh"
[ -d /home/linuxbrew/.linuxbrew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ]          && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
command -v direnv  >/dev/null 2>&1 && eval "$(direnv hook bash)"
command -v zoxide  >/dev/null 2>&1 && eval "$(zoxide init bash)"     # modernes cd: z <dir>
command -v fzf     >/dev/null 2>&1 && eval "$(fzf --bash 2>/dev/null)"

##### Editor #####
if command -v nvim >/dev/null 2>&1; then export EDITOR=nvim; else export EDITOR=vim; fi

##### History: keine Duplikate, gross, angehaengt #####
export HISTCONTROL=ignoreboth:erasedups
export HISTSIZE=100000
export HISTFILESIZE=200000
shopt -s histappend

##### Prompt: user@host:cwd, [ssh]-Marker wenn remote (nur in interaktiven Shells) #####
if [[ $- == *i* ]]; then
    [ -n "$SSH_CLIENT" ] && sshtxt="[ssh] "
    export PS1="\[\033[38;5;248m\]\u\[\033[0m\]\[\033[38;5;253m\]@\[\033[0m\]\[\033[38;5;113m\]\H\[\033[0m\]\[\033[38;5;15m\]:\[\033[0m\]\[\033[38;5;111m\]\w\[\033[0m\]\[\033[38;5;15m\]\n${sshtxt}\[\033[0m\]\[\033[38;5;253m\]\\$\[\033[0m\]\[\033[38;5;15m\] \[\033[0m\]"
fi

##### Lokale Maschinen-Overrides (nie im Repo) #####
[ -r "${HOME}/.bashrc.local" ] && . "${HOME}/.bashrc.local"
