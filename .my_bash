# ~/.dotfiles/.my_bash — bash-Funktionen, Prompt, PATH, Tool-Hooks
# Wird von ~/.bashrc gesourct (eine geguardete Zeile, via install.sh).

##### tm: DIE kanonische Orko-Session — Highlander, Name IMMER 'orko' #####
# Ein Wort -> rein in die Werkbank. Session existiert -> attach. Sonst -> neu,
# leer, in ~/orko. NIEMALS eine zweite Session spawnen (User-Direktive 2026-06-13).
# Claude startest du SELBST im Window (einfach 'claude' tippen).
# Detach: Ctrl+a d  |  zurueck: tm  |  Liste: tmls
# Die Logik als EIN inline-Befehl, damit sie remote (ueber ssh) identisch laeuft —
# unabhaengig davon, ob das Remote-.bashrc in nicht-interaktiven Shells abbricht
# (klassische "If not running interactively, don't do anything"-Falle).
__orko_attach='sess=orko; root="$HOME/orko"; \
command -v tmux >/dev/null 2>&1 || { echo "tmux fehlt"; exit 1; }; \
if tmux has-session -t "$sess" 2>/dev/null; then exec tmux attach -t "$sess"; \
else exec tmux new-session -s "$sess" -c "$root"; fi'

tm() {
    eval "$__orko_attach"
}
alias tmls="tmux ls"

# tmux-Server killen — mit Nachfrage (24/7-Sessions sind eine Fusswaffe)
tmk() {
    read -rp "Wirklich ALLE tmux-Sessions killen? (y/N) " a
    [[ "$a" =~ ^[Yy]$ ]] && tmux kill-server
}

##### git: schneller add+commit+push (nimmt ALLES untracked mit — bewusst grob) #####
gdrop() {
    git add -A && git commit -m "${1:-auto commit}" && git push
}

##### battlecat: ein Wort -> rein in die Werkbank #####
# Lokal AUF battlecat:  identisch zu 'tm' (attach an 'orko', sonst neu).
# Von WSL2/woanders:    mosh (ueberlebt WLAN-Wechsel/Schlaf) -> LAN wenn erreichbar,
#                       sonst MyFRITZ. Landet direkt in tmux 'orko'.
# Secrets (MyFRITZ-Adresse, LAN-IP, Port) kommen aus ~/.config/battlecat.env
#   (LOKAL, NICHT im oeffentlichen dotfiles-Repo). Ohne env -> klarer Hinweis.
battlecat() {
    # Lokal auf battlecat selbst: direkt in tmux, kein Netz.
    if [[ "$(hostname)" == "battlecat" ]]; then
        eval "$__orko_attach"; return
    fi
    # Remote: Secrets laden
    local envf="$HOME/.config/battlecat.env"
    [[ -r "$envf" ]] || { echo "🐱 ~/.config/battlecat.env fehlt — leg sie an (BATTLECAT_EXT/LAN/PORT/USER)"; return 1; }
    # shellcheck disable=SC1090
    . "$envf"
    command -v mosh >/dev/null 2>&1 || { echo "mosh fehlt: sudo apt install mosh"; return 1; }
    # LAN in 1s testen, sonst MyFRITZ
    local host
    if command -v nc >/dev/null 2>&1 && nc -z -w1 "$BATTLECAT_LAN" "$BATTLECAT_PORT" 2>/dev/null; then
        host="$BATTLECAT_LAN"; echo "🐱 battlecat via LAN ($host)"
    else
        host="$BATTLECAT_EXT"; echo "🐱 battlecat via MyFRITZ ($host)"
    fi
    # mosh: SSH nur fuer Handshake (Port + Key), dann UDP. Direkt in tmux 'orko'.
    exec mosh --ssh="ssh -p $BATTLECAT_PORT -i $HOME/.ssh/iterp" "$BATTLECAT_USER@$host" -- bash -lc "$__orko_attach"
}

##### aliases laden #####
[ -r "${HOME}/.dotfiles/.my_aliases" ] && . "${HOME}/.dotfiles/.my_aliases"

##### PATH #####
[ -d "${HOME}/bin" ]        && export PATH="${HOME}/bin:$PATH"
[ -d "${HOME}/.local/bin" ] && export PATH="${HOME}/.local/bin:$PATH"
[ -d "${HOME}/.cargo/bin" ] && export PATH="${HOME}/.cargo/bin:$PATH"

##### Tool-Hooks (alle geguarded — kosten nichts, wenn nicht installiert) #####
[ -r "${HOME}/miniconda3/etc/profile.d/conda.sh" ] && . "${HOME}/miniconda3/etc/profile.d/conda.sh"
[ -d /home/linuxbrew/.linuxbrew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ]          && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
command -v direnv  >/dev/null 2>&1 && eval "$(direnv hook bash)"
command -v zoxide  >/dev/null 2>&1 && eval "$(zoxide init bash)"     # modernes cd: z <dir>
command -v fzf     >/dev/null 2>&1 && eval "$(fzf --bash 2>/dev/null)"

##### Editor #####
if command -v nvim >/dev/null 2>&1; then export EDITOR=nvim; else export EDITOR=vim; fi

##### History: keine Duplikate, gross, angehaengt #####
export HISTCONTROL=ignoreboth:erasedups
export HISTSIZE=100000
export HISTFILESIZE=200000
shopt -s histappend

##### Prompt: user@host:cwd, [ssh]-Marker wenn remote (nur in interaktiven Shells) #####
if [[ $- == *i* ]]; then
    [ -n "$SSH_CLIENT" ] && sshtxt="[ssh] "
    export PS1="\[\033[38;5;248m\]\u\[\033[0m\]\[\033[38;5;253m\]@\[\033[0m\]\[\033[38;5;113m\]\H\[\033[0m\]\[\033[38;5;15m\]:\[\033[0m\]\[\033[38;5;111m\]\w\[\033[0m\]\[\033[38;5;15m\]\n${sshtxt}\[\033[0m\]\[\033[38;5;253m\]\\$\[\033[0m\]\[\033[38;5;15m\] \[\033[0m\]"
fi

##### Lokale Maschinen-Overrides (nie im Repo) #####
[ -r "${HOME}/.bashrc.local" ] && . "${HOME}/.bashrc.local"
